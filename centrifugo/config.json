{
  "client": {
    "proxy": {
      "connect": {
        "enabled": true,
        "endpoint": "http://backend:8080/centrifugo/connect"
      }
    },
    "token": {
      "hmac_secret_key": "decentrarent-dev-jwt-secret-change-in-production"
    },
    "allowed_origins": ["http://localhost:5173"]
  },
  "admin": {
    "enabled": true,
    "password": "admin",
    "secret": "admin-secret"
  },
  "http_api": {
    "key": "api-secret"
  },
  "channel": {
    "proxy": {
      "subscribe": {
        "endpoint": "http://backend:8080/centrifugo/subscribe"
      },
      "publish": {
        "endpoint": "http://backend:8080/centrifugo/publish"
      }
    },
    "namespaces": [
      {
        "name": "property",
        "history_size": 50,
        "history_ttl": "720h",
        "allow_subscribe_for_client": true,
        "allow_publish_for_subscriber": true,
        "force_recovery": true,
        "subscribe_proxy_enabled": true,
        "publish_proxy_enabled": true
      },
      {
        "name": "orders",
        "allow_subscribe_for_client": true,
        "allow_publish_for_subscriber": true
      }
    ]
  }
}
